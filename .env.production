# Public canonical origin. Baked into the client bundle at `vite build` and read
# by the prerender / sitemap / og-image scripts (via scripts/site-config.mjs) so
# canonical, Open Graph, JSON-LD and sitemap all point at one place. Public
# value, safe to commit. Change it here if the production domain moves.
VITE_SITE_URL=https://my-canvas-lab.vercel.app
